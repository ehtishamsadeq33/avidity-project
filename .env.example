# Coach Readiness Assessment - Environment Variables
# Copy these into your Replit Secrets panel (left sidebar → Secrets)
# DO NOT put real values here - this file is just a template

# MongoDB connection string (e.g., from MongoDB Atlas)
MONGODB_URI=

# Secret key for signing admin JWT tokens (use any long random string)
ADMIN_JWT_SECRET=

# Node environment (development or production)
NODE_ENV=development
